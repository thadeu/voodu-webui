<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Voodu" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Voodu">
    <meta name="application-name" content="Voodu">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#0a0d14">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="manifest" href="/manifest">

    <link rel="preload" href="/fonts/voodu/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/voodu/GeistMono-Variable.woff2" as="font" type="font/woff2" crossorigin>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <%= yield %>

    <% if Rails.env.production? %>
      <script>
        if ("serviceWorker" in navigator) {
          window.addEventListener("load", function () {
            navigator.serviceWorker
              .register("/service-worker", { scope: "/" })
              .catch(function (err) {
                console.warn("[voodu] service worker registration failed:", err);
              });
          });
        }
      </script>
    <% end %>
  </body>
</html>
