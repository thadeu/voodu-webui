<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Voodu" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Voodu">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Geist + Geist Mono are self-hosted under public/fonts/voodu/.
        Preload the variable woff2 so first paint already has the
        webfont (no FOUT swap). Same Origin → no preconnect needed. %>
    <link rel="preload" href="/fonts/voodu/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/voodu/GeistMono-Variable.woff2" as="font" type="font/woff2" crossorigin>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
