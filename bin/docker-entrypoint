#!/bin/bash
set -e

# Auto-generate and persist SECRET_KEY_BASE + ActiveRecord Encryption keys on first boot
# when no credentials are wired up. Both persist to the storage volume across restarts.
if [ -z "${RAILS_MASTER_KEY:-}" ] && [ ! -f /rails/config/master.key ]; then
  mkdir -p /rails/storage

  if [ -z "${SECRET_KEY_BASE:-}" ]; then
    SKB_FILE="/rails/storage/.secret_key_base"
    if [ -f "$SKB_FILE" ]; then
      SECRET_KEY_BASE="$(cat "$SKB_FILE")"
    else
      SECRET_KEY_BASE="$(openssl rand -hex 64)"
      umask 077 && printf '%s' "$SECRET_KEY_BASE" > "$SKB_FILE"
    fi
    export SECRET_KEY_BASE
  fi

  if [ -z "${ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY:-}" ]; then
    AR_ENC_FILE="/rails/storage/.ar_encryption.env"
    if [ ! -f "$AR_ENC_FILE" ]; then
      umask 077 && {
        printf 'ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=%s\n'         "$(openssl rand -hex 16)"
        printf 'ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=%s\n'   "$(openssl rand -hex 16)"
        printf 'ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=%s\n' "$(openssl rand -hex 16)"
      } > "$AR_ENC_FILE"
    fi
    set -a; . "$AR_ENC_FILE"; set +a
  fi
fi

# Auto-generate the internal poller token when the poller is on (POLLER_SPAWN=1,
# the image default) and none was supplied, so `docker run` stays near-zero-config.
# Rails (the InternalEndpointAuth check) and the poller binary the Puma plugin
# spawns both read POLLER_TOKEN from the env, so exporting one value here makes
# them agree. Persisted to the storage volume (like SECRET_KEY_BASE) so it's
# stable across restarts. An operator-supplied POLLER_TOKEN always wins.
if [ "${POLLER_SPAWN:-}" = "1" ] && [ -z "${POLLER_TOKEN:-}" ]; then
  mkdir -p /rails/storage
  PT_FILE="/rails/storage/.poller_token"

  if [ -f "$PT_FILE" ]; then
    POLLER_TOKEN="$(cat "$PT_FILE")"
  else
    POLLER_TOKEN="$(openssl rand -hex 32)"
    umask 077 && printf '%s' "$POLLER_TOKEN" > "$PT_FILE"
  fi
  
  export POLLER_TOKEN
fi

# If running the rails server (directly or wrapped by Thruster), create/migrate/seed the DB.
# db:prepare is idempotent: first boot = create + schema load + seed; subsequent boots = pending migrations only.
if [ "${@: -2:1}" = "./bin/rails" ] && [ "${@: -1:1}" = "server" ]; then
  ./bin/rails db:prepare
fi

exec "$@"
