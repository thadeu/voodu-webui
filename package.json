{
  "name": "voodu-webui",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:css": "pnpm exec tailwindcss -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css --minify",
    "lint": "eslint app/javascript",
    "lint:fix": "eslint app/javascript --fix",
    "fonts:copy": "mkdir -p public/fonts/voodu && cp node_modules/geist/dist/fonts/geist-sans/Geist-Variable.woff2 node_modules/geist/dist/fonts/geist-mono/GeistMono-Variable.woff2 public/fonts/voodu/",
    "postinstall": "pnpm run fonts:copy"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.23",
    "@tailwindcss/cli": "^4.3.0",
    "geist": "^1.7.1",
    "sortablejs": "^1.15.7",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.0",
    "esbuild-rails": "^1.0.7",
    "eslint": "^10.5.0",
    "globals": "^17.6.0"
  }
}
