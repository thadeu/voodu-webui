#!/usr/bin/env ruby
# frozen_string_literal: true

# bin/log-poller — Rails app binstub template.
#
# Installed into the host Rails app's `bin/` directory by
# LogPoller::Railtie on first boot. Boots the app (so credentials and
# autoload are available) and then hands off to LogPoller::Runner,
# which exec(3)s the compiled binary.
require_relative "../config/boot"
require "log_poller/runner"

LogPoller::Runner.start
